generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Figure {
  id             String    @id @default(cuid())
  slug           String    @unique
  name           String
  character      String
  series         String
  arc            String?
  releaseDate    DateTime?
  msrp           Float?
  msrpJpy        Int?
  janCode        String?   @unique
  isWebExclusive Boolean   @default(false)
  isRerelease    Boolean   @default(false)
  isThirdParty   Boolean   @default(false)
  version        String?
  description    String?
  accessories    String[]
  images         String[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  collections UserCollection[]
  priceSales  PriceSale[]
}

model User {
  id         String   @id @default(cuid())
  supabaseId String   @unique
  username   String   @unique
  email      String   @unique
  avatar     String?
  bio        String?
  isAdmin    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  collections UserCollection[]
  priceSales  PriceSale[]
}

model UserCollection {
  id            String           @id @default(cuid())
  userId        String
  figureId      String
  status        CollectionStatus
  quantity      Int              @default(1)
  purchasePrice Float?
  condition     String?
  notes         String?
  addedAt       DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  figure Figure @relation(fields: [figureId], references: [id], onDelete: Cascade)

  @@unique([userId, figureId])
}

model PriceSale {
  id          String   @id @default(cuid())
  figureId    String
  price       Float
  saleDate    DateTime
  source      String
  condition   String?
  notes       String?
  sourceUrl   String?
  externalId  String?  @unique
  submittedBy String?
  createdAt   DateTime @default(now())

  figure Figure @relation(fields: [figureId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [submittedBy], references: [id])
}

enum CollectionStatus {
  OWNED
  WISHLIST
  FOR_SALE
}
